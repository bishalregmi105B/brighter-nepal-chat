# BrighterNepal Chat Service — Environment Variables
# Copy this to .env and fill in your values

# JWT key must match brighter-nepal-api's JWT_SECRET_KEY exactly
SECRET_KEY=brighter-nepal-super-secret-key-change-in-production
JWT_SECRET_KEY=jwt-brighter-nepal-secret-change-in-production

# Point to the SAME database the main API uses
# SQLite (development)
DATABASE_URI=sqlite:///../brighter-nepal-api/instance/brighter_nepal.db
# PostgreSQL (production example)
# DATABASE_URI=postgresql://user:pass@localhost/brighter_nepal

# Redis URL (required for multi-worker / production scaling)
# Local:
REDIS_URL=redis://localhost:6379/0
# Upstash (cloud free tier):
# REDIS_URL=rediss://:password@your-instance.upstash.io:6380

# Allowed CORS origins (comma-separated)
FRONTEND_URL=http://localhost:3000

# Port for this service
CHAT_PORT=5001
